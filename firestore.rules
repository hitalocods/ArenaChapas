rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "adm123@gmail.com";
    }

    function isValidReservationCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          "quadra",
          "quadraId",
          "tipoQuadra",
          "data",
          "horarios",
          "status",
          "nomeCliente",
          "telefoneCliente",
          "createdAt"
        ])
        && data.quadra is string
        && data.quadraId is string
        && data.tipoQuadra is string
        && data.data is string
        && data.horarios is list
        && data.horarios.size() > 0
        && data.horarios.size() <= 5
        && data.status == "reservado"
        && data.nomeCliente is string
        && data.telefoneCliente is string
        && data.createdAt is string;
    }

    function isValidClientCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          "nomeCliente",
          "telefoneCliente",
          "ultimaReservaEm",
          "origem"
        ])
        && data.nomeCliente is string
        && data.telefoneCliente is string
        && data.ultimaReservaEm is string
        && data.origem == "site";
    }

    match /reservas/{reservaId} {
      allow create: if isValidReservationCreate();
      allow read, update, delete: if isAdmin();
    }

    match /clientes/{clienteId} {
      allow create: if isValidClientCreate();
      allow read, update, delete: if isAdmin();
    }

    match /agenda/{slotId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
          "quadraId",
          "quadra",
          "data",
          "horario",
          "status",
          "reservaId",
          "updatedAt"
        ])
        && request.resource.data.quadraId is string
        && request.resource.data.quadra is string
        && request.resource.data.data is string
        && request.resource.data.horario is string
        && request.resource.data.status == "reservado"
        && request.resource.data.reservaId is string
        && request.resource.data.updatedAt is string;
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
